{
  "name": "ball-bounce-game",
  "version": "1.1.0",
  "description": "A JavaScript-based Android mobile game packaged via Apache Cordova",
  "main": "src/engine/GameEngine.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "browserify src/engine/GameEngine.js --standalone GameEngine -o www/js/bundle.js",
    "serve": "node scripts/serve.js",
    "dev": "npm run build && npm run serve"
  },
  "dependencies": {
    "planck-js": "1.3.0",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "browserify": "^17.0.1",
    "cordova-android": "^13.0.0",
    "fast-check": "3.22.0",
    "jest": "29.7.0",
    "jest-environment-node": "29.7.0"
  },
  "keywords": [
    "game",
    "android",
    "cordova",
    "physics"
  ],
  "license": "MIT",
  "cordova": {
    "platforms": [
      "android"
    ]
  }
}
